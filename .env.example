# Backend
API_HOST=0.0.0.0
API_PORT=8765
API_RELOAD=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Authentication: set strong values before deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
USER_USERNAME=user
USER_PASSWORD=change-me-user
FRONTEND_URL=http://localhost:5173

# LLM providers
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b
GROQ_API_KEY=
GROQ_MODEL=medical

# Retrieval
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_INDEX=clinical-rag-index
PINECONE_MIN_SCORE=0.45
ENABLE_NER=false
